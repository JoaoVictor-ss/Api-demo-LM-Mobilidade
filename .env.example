# Tavily (endpoint legado /search_vehicle). Opcional: os endpoints /webmotors
# não dependem dela.
TAVILY_API_KEY=

# --- AWS Bedrock Agent (endpoint /recommendation e UI) ---
# Credenciais AWS seguem o padrão do boto3: AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN, perfil local ou IAM role.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_PROFILE=
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=

# --- Scraper Webmotors (opcional, têm defaults) ---

# Caminho do Chrome REAL usado no mint do PerimeterX. Detectado automaticamente
# por SO; só preencha se o Chrome estiver em local não-padrão.
#   macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Linux:   /usr/bin/google-chrome
#   Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# WEBMOTORS_CHROME_PATH=

# User-Agent. Default já coerente com o SO (Windows/macOS/Linux). No bypass por
# cookie, use o UA do navegador onde você colheu os cookies.
# WEBMOTORS_UA=

# Bypass do browser: se você já tem cookies válidos, cole aqui e o mint via
# Chrome nem é chamado. Ex: "_px3=...; _pxvid=...; pxcts=...; _pxde=..."
# WEBMOTORS_COOKIE=

# Onde guardar a sessão em cache e o perfil do Chrome (default: diretório
# temporário do SO).
# WEBMOTORS_CACHE=
# WEBMOTORS_PROFILE_DIR=
# WEBMOTORS_SESSION_TTL=480
# WEBMOTORS_MINT_ATTEMPTS=3
